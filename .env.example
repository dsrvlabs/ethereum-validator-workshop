# ── Ethereum Validator Workshop — 환경 변수 ──────────────────────
# 복사해서 .env 로 사용:  cp .env.example .env  &&  vi .env

# 네트워크
NETWORK=hoodi
CHECKPOINT_URL=https://hoodi.beaconstate.ethstaker.cc

# 검증자 — 블록 제안 보상(EL 팁/MEV)을 받을 본인 EOA 주소 (필수)
# ⚠ 아래는 예시 주소입니다 — 반드시 본인 EOA 주소로 교체하세요
FEE_RECIPIENT=0x0dC0CA2fC216177041DbE01d8C1DeA9621eb8801
GRAFFITI=dsrv-workshop

# MEV-Boost — Hoodi relay 목록(쉼표 구분, 공백 없이). 여러 relay 중 가장 높은 입찰 선택.
#   출처: ethstaker-guides/MEV-relay-list (2026-06 확인) — 가용성은 변할 수 있으니 발표 전 재확인
#   Flashbots: https://0xafa4c6985aa049fb79dd37010438cfebeb0f2bd42b115b89dd678dab0670c1de38da0c4e9138c9290a398ecd9a0b3110@boost-relay-hoodi.flashbots.net
#   Aestus:    https://0x98f0ef62f00780cf8eb06701a7d22725b9437d4768bb19b363e882ae87129945ec206ec2dc16933f31d983f8225772b6@hoodi.aestus.live
#   Titan:     https://0xaa58208899c6105603b74396734a6263cc7d947f444f396a90f7b7d3e65d102aec7e5e5291b27e08d02c50a050825c2f@hoodi.titanrelay.xyz
#   bloXroute: https://0x821f2a65afb70e7f2e820a925a9b4c80a159620582c1766b1b09729fec178b11ea22abb3a51f07b288be815a1a2ff516@bloxroute.hoodi.blxrbdn.com
MEV_RELAYS=https://0xafa4c6985aa049fb79dd37010438cfebeb0f2bd42b115b89dd678dab0670c1de38da0c4e9138c9290a398ecd9a0b3110@boost-relay-hoodi.flashbots.net,https://0x98f0ef62f00780cf8eb06701a7d22725b9437d4768bb19b363e882ae87129945ec206ec2dc16933f31d983f8225772b6@hoodi.aestus.live

# Grafana 초기 비밀번호
GRAFANA_PASSWORD=changeme

# 클라이언트 이미지 버전 — 실습 전 GitHub Releases 에서 최신 확인
#   github.com/ethereum/go-ethereum/releases  ·  github.com/sigp/lighthouse/releases
GETH_VERSION=v1.17.3
LIGHTHOUSE_VERSION=v8.1.3
#   github.com/flashbots/mev-boost/releases  (Docker 태그는 v 없이 숫자)
MEV_BOOST_VERSION=1.12
